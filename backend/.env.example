# Exemplo de variáveis de ambiente. Copie para .env e ajuste.
# SECRET_KEY do Django (gere uma nova com: python -c "import secrets; print(secrets.token_urlsafe(50))")
SECRET_KEY=trocar-por-uma-chave-real
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# IA (opcional) - deixe vazio p/ usar "modo simulação"
AI_API_KEY=
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini